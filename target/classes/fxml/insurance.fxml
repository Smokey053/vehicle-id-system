<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.effect.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.plateiq.controller.InsuranceController"
            prefHeight="700.0" prefWidth="1000.0"
            style="-fx-background-color: #f5f7fa;">

    <children>
        <!-- Title -->
        <Label text="Insurance Management" styleClass="page-title" AnchorPane.topAnchor="10.0" AnchorPane.leftAnchor="20.0">
            <font>
                <Font name="Segoe UI" size="24.0" />
            </font>
        </Label>

        <!-- Policy Form -->
        <TitledPane text="Add Insurance Policy" AnchorPane.topAnchor="50.0" AnchorPane.leftAnchor="20.0"
                    AnchorPane.rightAnchor="20.0" prefHeight="180.0">
            <content>
                <GridPane hgap="15.0" vgap="10.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="150.0" prefWidth="200.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="150.0" prefWidth="200.0" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints vgrow="SOMETIMES" />
                        <RowConstraints vgrow="SOMETIMES" />
                        <RowConstraints vgrow="SOMETIMES" />
                        <RowConstraints vgrow="SOMETIMES" />
                    </rowConstraints>
                    <children>
                        <Label text="Policy Number:" />
                        <TextField fx:id="policyNumberField" GridPane.columnIndex="1" />

                        <Label text="Insurance Company:" GridPane.rowIndex="1" />
                        <TextField fx:id="insuranceCompanyField" GridPane.columnIndex="1" />

                        <Label text="Vehicle Plate:" GridPane.rowIndex="2" />
                        <TextField fx:id="vehiclePlateField" GridPane.columnIndex="1" />

                        <Label text="Coverage Details:" GridPane.rowIndex="3" GridPane.columnSpan="2" />
                        <TextArea fx:id="coverageArea" prefHeight="60.0" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                    </children>
                </GridPane>
            </content>
        </TitledPane>

        <!-- Expiry Progress Bar -->
        <TitledPane text="Policy Expiry Status" AnchorPane.topAnchor="240.0" AnchorPane.leftAnchor="20.0"
                    AnchorPane.rightAnchor="20.0" prefHeight="60.0">
            <content>
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <ProgressBar fx:id="expiryProgressBar" prefWidth="300.0" />
                        <Label fx:id="expiryLabel" text="Valid: 0 | Expiring Soon: 0 | Expired: 0" />
                    </children>
                </HBox>
            </content>
        </TitledPane>

        <!-- Policy Table -->
        <TitledPane text="Insurance Policies" AnchorPane.topAnchor="310.0" AnchorPane.leftAnchor="20.0"
                    AnchorPane.rightAnchor="20.0" prefHeight="200.0">
            <content>
                <TableView fx:id="policyTable" prefHeight="180.0">
                    <columns>
                        <TableColumn fx:id="colPolicyId" text="ID" prefWidth="60.0" />
                        <TableColumn fx:id="colVehiclePlate" text="Vehicle" prefWidth="120.0" />
                        <TableColumn fx:id="colCompany" text="Company" prefWidth="150.0" />
                        <TableColumn fx:id="colPolicyNumber" text="Policy Number" prefWidth="150.0" />
                        <TableColumn fx:id="colStartDate" text="Start Date" prefWidth="120.0" />
                        <TableColumn fx:id="colEndDate" text="End Date" prefWidth="120.0" />
                    </columns>
                </TableView>
            </content>
        </TitledPane>

        <!-- Claims Section -->
        <TitledPane text="Claims Management" AnchorPane.topAnchor="520.0" AnchorPane.leftAnchor="20.0"
                    AnchorPane.rightAnchor="20.0" prefHeight="180.0">
            <content>
                <GridPane hgap="15.0" vgap="10.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="150.0" prefWidth="200.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="150.0" prefWidth="200.0" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints vgrow="SOMETIMES" />
                        <RowConstraints vgrow="SOMETIMES" />
                        <RowConstraints vgrow="SOMETIMES" />
                    </rowConstraints>
                    <children>
                        <Label text="Claim Amount ($):" />
                        <TextField fx:id="claimAmountField" GridPane.columnIndex="1" />

                        <Label text="Description:" GridPane.rowIndex="1" />
                        <TextArea fx:id="claimDescriptionArea" prefHeight="60.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <Button text="Submit Claim" onAction="#addClaim" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                    </children>
                </GridPane>
            </content>
        </TitledPane>

        <!-- Claims Table -->
        <TitledPane text="All Claims" AnchorPane.topAnchor="520.0" AnchorPane.leftAnchor="20.0"
                    AnchorPane.rightAnchor="20.0" AnchorPane.bottomAnchor="20.0">
            <content>
                <TableView fx:id="claimTable" prefHeight="150.0">
                    <columns>
                        <TableColumn fx:id="colClaimId" text="ID" prefWidth="60.0" />
                        <TableColumn fx:id="colPolicyNum" text="Policy" prefWidth="150.0" />
                        <TableColumn fx:id="colClaimDate" text="Date" prefWidth="120.0" />
                        <TableColumn fx:id="colClaimAmount" text="Amount ($)" prefWidth="120.0" />
                        <TableColumn fx:id="colStatus" text="Status" prefWidth="100.0" />
                    </columns>
                </TableView>
            </content>
        </TitledPane>

        <!-- Action Buttons -->
        <HBox alignment="CENTER" spacing="15.0" AnchorPane.bottomAnchor="50.0" AnchorPane.leftAnchor="20.0">
            <children>
                <Button text="Add Policy" onAction="#addPolicy" styleClass="primary-button" />
                <Button text="Update Status" onAction="#updateClaimStatus" styleClass="secondary-button" />
                <Button text="Search" onAction="#searchPolicy" styleClass="outline-button" />
            </children>
        </HBox>
    </children>
</AnchorPane>