<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.paint.*?>
<?import javafx.animation.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.plateiq.controller.LoginController"
            prefHeight="600.0" prefWidth="800.0"
            style="-fx-background: linear-gradient(to bottom right, #f8fafc, #e2e8f0);">

    <children>
        <!-- Login Card -->
        <StackPane alignment="CENTER" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
                   AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
            <AnchorPane prefWidth="420.0" prefHeight="500.0" style="-fx-background-color: white; -fx-background-radius: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 30, 0, 0, 10);">
                <children>
                    <!-- Title Section -->
                    <VBox alignment="CENTER" spacing="10.0" AnchorPane.topAnchor="60.0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
                        <children>
                            <Label text="Plate IQ" styleClass="title-label">
                                <font>
                                    <Font name="Inter" size="42.0" />
                                </font>
                                <textFill>
                                    <Color red="0.1" green="0.2" blue="0.3" />
                                </textFill>
                            </Label>
                            <Label text="Enterprise Vehicle Management" styleClass="subtitle-label">
                                <font>
                                    <Font name="Inter" size="14.0" />
                                </font>
                                <textFill>
                                    <Color red="0.5" green="0.5" blue="0.5" />
                                </textFill>
                            </Label>
                        </children>
                    </VBox>

                    <!-- Login Form -->
                    <VBox alignment="CENTER" spacing="20.0" AnchorPane.topAnchor="160.0" AnchorPane.leftAnchor="40.0" AnchorPane.rightAnchor="40.0">
                        <children>
                            <VBox spacing="5.0">
                                <children>
                                    <Label text="Username" style="-fx-text-fill: #64748b; -fx-font-weight: bold;">
                                        <font><Font name="Inter" size="12.0" /></font>
                                    </Label>
                                    <TextField fx:id="usernameField" promptText="Enter your username" styleClass="form-field" />
                                </children>
                            </VBox>

                            <VBox spacing="5.0">
                                <children>
                                    <Label text="Password" style="-fx-text-fill: #64748b; -fx-font-weight: bold;">
                                        <font><Font name="Inter" size="12.0" /></font>
                                    </Label>
                                    <PasswordField fx:id="passwordField" promptText="Enter your password" styleClass="form-field" />
                                </children>
                            </VBox>

                            <Button fx:id="loginButton" text="Sign In" prefWidth="340.0" prefHeight="50.0"
                                    styleClass="primary-button" onAction="#handleLogin">
                                <font>
                                    <Font name="Inter" size="16.0" />
                                </font>
                            </Button>
                        </children>
                    </VBox>

                    <!-- Footer -->
                    <Label text="© 2026 Plate IQ Systems. All rights reserved." styleClass="footer-label"
                           AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="0.0"
                           AnchorPane.rightAnchor="0.0">
                        <font>
                            <Font name="Inter" size="11.0" />
                        </font>
                        <textFill>
                            <Color red="0.7" green="0.7" blue="0.7" />
                        </textFill>
                    </Label>
                </children>
            </AnchorPane>
        </StackPane>

        <!-- Welcome Animation (FadeTransition) -->
        <Label fx:id="welcomeLabel" text="Welcome back!" styleClass="welcome-label"
               AnchorPane.topAnchor="30.0" AnchorPane.rightAnchor="30.0">
            <font>
                <Font name="Inter" size="16.0" />
            </font>
            <textFill>
                <Color red="0.4" green="0.5" blue="0.6" />
            </textFill>
        </Label>
    </children>
</AnchorPane>
