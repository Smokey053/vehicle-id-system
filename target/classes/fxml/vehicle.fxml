<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.effect.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.plateiq.controller.VehicleController"
            prefHeight="700.0" prefWidth="1000.0"
            style="-fx-background-color: -fx-bg-secondary;">

    <children>
        <!-- Header Section -->
        <VBox spacing="10.0" AnchorPane.topAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <Button text="← Back to Dashboard" onAction="#goToDashboard" styleClass="outline-button" />
                        <Label text="Vehicle Management" styleClass="page-title">
                            <font>
                                <Font name="Inter" size="28.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>
                <Separator />
            </children>
        </VBox>

        <!-- Search Section -->
        <HBox alignment="CENTER_LEFT" spacing="15.0" AnchorPane.topAnchor="70.0" AnchorPane.leftAnchor="20.0"
              AnchorPane.rightAnchor="20.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);">
            <children>
                <TextField fx:id="searchField" promptText="Search by registration number..." prefWidth="400.0"
                           styleClass="search-field" />
                <Button text="Search" onAction="#searchVehicle" styleClass="primary-button" />
                <Button text="Clear" onAction="#clearSearch" styleClass="outline-button" />
            </children>
        </HBox>

        <!-- Vehicle Form -->
        <TitledPane text="Vehicle Details" AnchorPane.topAnchor="130.0" AnchorPane.leftAnchor="20.0"
                    AnchorPane.rightAnchor="20.0" prefHeight="220.0" styleClass="form-pane">
            <content>
                <GridPane hgap="20.0" vgap="15.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="150.0" prefWidth="200.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="150.0" prefWidth="200.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="150.0" prefWidth="200.0" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints vgrow="SOMETIMES" />
                        <RowConstraints vgrow="SOMETIMES" />
                        <RowConstraints vgrow="SOMETIMES" />
                    </RowConstraints>
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <Label text="Registration Number" style="-fx-text-fill: #64748b; -fx-font-size: 12;" />
                                <TextField fx:id="plateNumberField" />
                            </children>
                        </VBox>
                        <VBox spacing="5.0" GridPane.columnIndex="1">
                            <children>
                                <Label text="Brand" style="-fx-text-fill: #64748b; -fx-font-size: 12;" />
                                <TextField fx:id="brandField" />
                            </children>
                        </VBox>
                        <VBox spacing="5.0" GridPane.columnIndex="2">
                            <children>
                                <Label text="Model" style="-fx-text-fill: #64748b; -fx-font-size: 12;" />
                                <TextField fx:id="modelField" />
                            </children>
                        </VBox>

                        <VBox spacing="5.0" GridPane.rowIndex="1">
                            <children>
                                <Label text="Year" style="-fx-text-fill: #64748b; -fx-font-size: 12;" />
                                <TextField fx:id="yearField" />
                            </children>
                        </VBox>
                        <VBox spacing="5.0" GridPane.rowIndex="1" GridPane.columnIndex="1">
                            <children>
                                <Label text="Color" style="-fx-text-fill: #64748b; -fx-font-size: 12;" />
                                <TextField fx:id="colorField" />
                            </children>
                        </VBox>
                        <VBox spacing="5.0" GridPane.rowIndex="1" GridPane.columnIndex="2">
                            <children>
                                <Label text="Owner Name" style="-fx-text-fill: #64748b; -fx-font-size: 12;" />
                                <TextField fx:id="ownerNameField" />
                            </children>
                        </VBox>

                        <VBox spacing="5.0" GridPane.rowIndex="2" GridPane.columnSpan="3">
                            <children>
                                <Label text="Owner Phone" style="-fx-text-fill: #64748b; -fx-font-size: 12;" />
                                <TextField fx:id="ownerPhoneField" GridPane.columnSpan="3" />
                            </children>
                        </VBox>
                    </children>
                </GridPane>
            </content>
        </TitledPane>

        <!-- CRUD Buttons -->
        <HBox alignment="CENTER_LEFT" spacing="15.0" AnchorPane.topAnchor="360.0" AnchorPane.leftAnchor="20.0">
            <children>
                <Button text="Add Vehicle" onAction="#addVehicle" styleClass="primary-button" />
                <Button text="Edit Vehicle" onAction="#editVehicle" styleClass="secondary-button" />
                <Button text="Delete Vehicle" onAction="#deleteVehicle" styleClass="danger-button" />
                <Button text="Clear Form" onAction="#clearFields" styleClass="outline-button" />
            </children>
        </HBox>

        <!-- Vehicle Table -->
        <TitledPane text="Vehicle List" AnchorPane.topAnchor="410.0" AnchorPane.leftAnchor="20.0"
                    AnchorPane.rightAnchor="20.0" AnchorPane.bottomAnchor="80.0" styleClass="table-pane">
            <content>
                <TableView fx:id="vehicleTable" prefHeight="300.0">
                    <columns>
                        <TableColumn fx:id="colPlateNumber" text="Registration" prefWidth="120.0" />
                        <TableColumn fx:id="colBrand" text="Brand" prefWidth="100.0" />
                        <TableColumn fx:id="colModel" text="Model" prefWidth="100.0" />
                        <TableColumn fx:id="colYear" text="Year" prefWidth="80.0" />
                        <TableColumn fx:id="colColor" text="Color" prefWidth="80.0" />
                        <TableColumn fx:id="colOwnerName" text="Owner" prefWidth="150.0" />
                        <TableColumn fx:id="colOwnerPhone" text="Phone" prefWidth="120.0" />
                    </columns>
                </TableView>
            </content>
        </TitledPane>

        <!-- Pagination -->
        <Pagination fx:id="pagination" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0"
                    AnchorPane.rightAnchor="20.0" />
    </children>
</AnchorPane>