<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.effect.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.plateiq.controller.VehicleController"
            prefHeight="700.0" prefWidth="1000.0"
            style="-fx-background-color: #f5f7fa;">

    <children>
        <!-- Title -->
        <Label text="Vehicle Management" styleClass="page-title" AnchorPane.topAnchor="10.0" AnchorPane.leftAnchor="20.0">
            <font>
                <Font name="Segoe UI" size="24.0" />
            </font>
        </Label>

        <!-- Search Section -->
        <HBox alignment="CENTER_LEFT" spacing="10.0" AnchorPane.topAnchor="50.0" AnchorPane.leftAnchor="20.0"
              AnchorPane.rightAnchor="20.0">
            <children>
                <TextField fx:id="searchField" promptText="Search by registration number..." prefWidth="300.0"
                           styleClass="search-field" />
                <Button text="Search" onAction="#searchVehicle" styleClass="primary-button" />
                <Button text="Clear" onAction="#clearSearch" styleClass="secondary-button" />
            </children>
        </HBox>

        <!-- Vehicle Form -->
        <TitledPane text="Vehicle Details" AnchorPane.topAnchor="90.0" AnchorPane.leftAnchor="20.0"
                    AnchorPane.rightAnchor="20.0" prefHeight="180.0">
            <content>
                <GridPane hgap="15.0" vgap="10.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="150.0" prefWidth="200.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="150.0" prefWidth="200.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="150.0" prefWidth="200.0" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints vgrow="SOMETIMES" />
                        <RowConstraints vgrow="SOMETIMES" />
                    </rowConstraints>
                    <children>
                        <Label text="Registration Number:" />
                        <TextField fx:id="plateNumberField" GridPane.columnIndex="1" />
                        <TextField fx:id="brandField" GridPane.columnIndex="2" />

                        <Label text="Brand:" GridPane.rowIndex="1" />
                        <Label text="Model:" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                        <TextField fx:id="modelField" GridPane.columnIndex="2" />

                        <Label text="Year:" GridPane.rowIndex="2" />
                        <TextField fx:id="yearField" GridPane.columnIndex="1" />
                        <Label text="Color:" GridPane.rowIndex="2" GridPane.columnIndex="2" />
                        <TextField fx:id="colorField" GridPane.columnIndex="3" />

                        <Label text="Owner Name:" GridPane.rowIndex="3" GridPane.columnSpan="2" />
                        <TextField fx:id="ownerNameField" GridPane.columnIndex="2" GridPane.columnSpan="2" />

                        <Label text="Owner Phone:" GridPane.rowIndex="4" GridPane.columnSpan="2" />
                        <TextField fx:id="ownerPhoneField" GridPane.columnIndex="2" GridPane.columnSpan="2" />
                    </children>
                </GridPane>
            </content>
        </TitledPane>

        <!-- CRUD Buttons -->
        <HBox alignment="CENTER" spacing="15.0" AnchorPane.topAnchor="280.0" AnchorPane.leftAnchor="20.0">
            <children>
                <Button text="Add Vehicle" onAction="#addVehicle" styleClass="primary-button" />
                <Button text="Edit Vehicle" onAction="#editVehicle" styleClass="secondary-button" />
                <Button text="Delete Vehicle" onAction="#deleteVehicle" styleClass="danger-button" />
                <Button text="Clear Form" onAction="#clearFields" styleClass="outline-button" />
            </children>
        </HBox>

        <!-- Vehicle Table -->
        <TitledPane text="Vehicle List" AnchorPane.topAnchor="320.0" AnchorPane.leftAnchor="20.0"
                    AnchorPane.rightAnchor="20.0" AnchorPane.bottomAnchor="80.0">
            <content>
                <TableView fx:id="vehicleTable" prefHeight="300.0">
                    <columns>
                        <TableColumn fx:id="colPlateNumber" text="Registration" prefWidth="120.0" />
                        <TableColumn fx:id="colBrand" text="Brand" prefWidth="100.0" />
                        <TableColumn fx:id="colModel" text="Model" prefWidth="100.0" />
                        <TableColumn fx:id="colYear" text="Year" prefWidth="80.0" />
                        <TableColumn fx:id="colColor" text="Color" prefWidth="80.0" />
                        <TableColumn fx:id="colOwnerName" text="Owner" prefWidth="150.0" />
                        <TableColumn fx:id="colOwnerPhone" text="Phone" prefWidth="120.0" />
                    </columns>
                </TableView>
            </content>
        </TitledPane>

        <!-- Pagination -->
        <Pagination fx:id="pagination" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0"
                    AnchorPane.rightAnchor="20.0" />
    </children>
</AnchorPane>