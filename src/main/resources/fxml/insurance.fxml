<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.plateiq.controller.InsuranceController"
            prefHeight="700.0" prefWidth="1000.0"
            styleClass="module-root">
    <top>
        <VBox spacing="10.0" styleClass="module-header" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="16.0" right="20.0" bottom="0.0" left="20.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <ImageView fitWidth="150.0" preserveRatio="true" styleClass="brand-logo">
                            <image>
                                <Image url="@../logo.png" />
                            </image>
                        </ImageView>
                        <Button text="← Back to Dashboard" onAction="#goToDashboard" styleClass="outline-button" />
                        <Label text="Insurance Management" styleClass="page-title">
                            <font>
                                <Font name="Segoe UI" size="24.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <children>
                        <Button fx:id="addPolicyButton" text="Add Policy" onAction="#addPolicy" styleClass="primary-button" />
                        <Button fx:id="submitClaimButton" text="Submit Claim" onAction="#addClaim" styleClass="secondary-button" />
                        <Button fx:id="updateClaimStatusButton" text="Update Claim Status" onAction="#updateClaimStatus" styleClass="outline-button" />
                        <Button text="Search Policy" onAction="#searchPolicy" styleClass="outline-button" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="module-scroll" BorderPane.alignment="CENTER">
            <content>
                <VBox spacing="12.0" styleClass="content-surface">
                    <padding>
                        <Insets top="12.0" right="20.0" bottom="20.0" left="20.0" />
                    </padding>
                    <children>
                        <TitledPane text="Policy Details" expanded="true">
                            <content>
                                <GridPane hgap="15.0" vgap="10.0">
                                    <columnConstraints>
                                        <ColumnConstraints minWidth="170.0" prefWidth="220.0" hgrow="SOMETIMES" />
                                        <ColumnConstraints minWidth="260.0" hgrow="ALWAYS" />
                                    </columnConstraints>
                                    <children>
                                        <Label text="Policy Number:" />
                                        <TextField fx:id="policyNumberField" GridPane.columnIndex="1" />

                                        <Label text="Insurance Company:" GridPane.rowIndex="1" />
                                        <TextField fx:id="insuranceCompanyField" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                        <Label text="Vehicle Plate:" GridPane.rowIndex="2" />
                                        <TextField fx:id="vehiclePlateField" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                        <Label text="Coverage Details:" GridPane.rowIndex="3" />
                                        <TextArea fx:id="coverageArea" prefRowCount="3" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                    </children>
                                </GridPane>
                            </content>
                        </TitledPane>

                        <TitledPane text="Policy Expiry Status" expanded="true">
                            <content>
                                <HBox alignment="CENTER_LEFT" spacing="18.0">
                                    <children>
                                        <ProgressBar fx:id="expiryProgressBar" prefWidth="320.0" />
                                        <Label fx:id="expiryLabel" text="Valid: 0 | Expiring Soon: 0 | Expired: 0" />
                                    </children>
                                </HBox>
                            </content>
                        </TitledPane>

                        <TitledPane text="Insurance Policies" expanded="true">
                            <content>
                                <TableView fx:id="policyTable" prefHeight="220.0">
                                    <columns>
                                        <TableColumn fx:id="colPolicyId" text="ID" prefWidth="60.0" />
                                        <TableColumn fx:id="colVehiclePlate" text="Vehicle" prefWidth="120.0" />
                                        <TableColumn fx:id="colCompany" text="Company" prefWidth="160.0" />
                                        <TableColumn fx:id="colPolicyNumber" text="Policy Number" prefWidth="160.0" />
                                        <TableColumn fx:id="colStartDate" text="Start Date" prefWidth="120.0" />
                                        <TableColumn fx:id="colEndDate" text="End Date" prefWidth="120.0" />
                                    </columns>
                                </TableView>
                            </content>
                        </TitledPane>

                        <TitledPane text="Claim Submission" expanded="true">
                            <content>
                                <GridPane hgap="15.0" vgap="10.0">
                                    <columnConstraints>
                                        <ColumnConstraints minWidth="170.0" prefWidth="220.0" hgrow="SOMETIMES" />
                                        <ColumnConstraints minWidth="260.0" hgrow="ALWAYS" />
                                    </columnConstraints>
                                    <children>
                                        <Label text="Claim Amount ($):" />
                                        <TextField fx:id="claimAmountField" GridPane.columnIndex="1" />

                                        <Label text="Description:" GridPane.rowIndex="1" />
                                        <TextArea fx:id="claimDescriptionArea" prefRowCount="3" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                    </children>
                                </GridPane>
                            </content>
                        </TitledPane>

                        <TitledPane text="Claims" expanded="true">
                            <content>
                                <TableView fx:id="claimTable" prefHeight="220.0">
                                    <columns>
                                        <TableColumn fx:id="colClaimId" text="ID" prefWidth="60.0" />
                                        <TableColumn fx:id="colPolicyNum" text="Policy" prefWidth="150.0" />
                                        <TableColumn fx:id="colClaimDate" text="Date" prefWidth="120.0" />
                                        <TableColumn fx:id="colClaimAmount" text="Amount ($)" prefWidth="130.0" />
                                        <TableColumn fx:id="colStatus" text="Status" prefWidth="120.0" />
                                    </columns>
                                </TableView>
                            </content>
                        </TitledPane>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
