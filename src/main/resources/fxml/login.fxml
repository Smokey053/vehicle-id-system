<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.paint.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.plateiq.controller.LoginController"
            prefHeight="600.0" prefWidth="800.0"
            styleClass="login-root">

    <children>
        <MenuBar AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <menus>
                <Menu text="File">
                    <items>
                        <MenuItem text="Home" onAction="#handleHome" />
                        <MenuItem text="Logout" onAction="#handleLogout" />
                        <SeparatorMenuItem />
                        <MenuItem text="Exit" onAction="#handleExit" />
                    </items>
                </Menu>
            </menus>
        </MenuBar>

        <!-- Login Card -->
        <StackPane alignment="CENTER" AnchorPane.topAnchor="30" AnchorPane.bottomAnchor="0"
                   AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
            <AnchorPane prefWidth="420.0" prefHeight="500.0" styleClass="login-card" style="-fx-effect: dropshadow(gaussian, rgba(0,0,0,0.18), 30, 0, 0, 10);">
                <children>
                    <!-- Title Section -->
                    <VBox alignment="CENTER" spacing="10.0" AnchorPane.topAnchor="42.0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
                        <children>
                            <ImageView fitWidth="260.0" preserveRatio="true" styleClass="brand-logo">
                                <image>
                                    <Image url="@../logo.png" />
                                </image>
                            </ImageView>
                            <Label text="Enterprise Vehicle Management" styleClass="subtitle-label">
                                <font>
                                    <Font name="Inter" size="14.0" />
                                </font>
                                <textFill>
                                    <Color red="0.5" green="0.5" blue="0.5" />
                                </textFill>
                            </Label>
                        </children>
                    </VBox>

                    <!-- Login Form -->
                    <VBox alignment="CENTER" spacing="20.0" AnchorPane.topAnchor="170.0" AnchorPane.leftAnchor="40.0" AnchorPane.rightAnchor="40.0">
                        <children>
                            <VBox spacing="5.0">
                                <children>
                                    <Label text="Username" style="-fx-text-fill: #64748b; -fx-font-weight: bold;">
                                        <font><Font name="Inter" size="12.0" /></font>
                                    </Label>
                                    <TextField fx:id="usernameField" promptText="Enter your username" styleClass="form-field" />
                                </children>
                            </VBox>

                            <VBox spacing="5.0">
                                <children>
                                    <Label text="Password" style="-fx-text-fill: #64748b; -fx-font-weight: bold;">
                                        <font><Font name="Inter" size="12.0" /></font>
                                    </Label>
                                    <HBox spacing="8.0" alignment="CENTER_LEFT">
                                        <children>
                                            <StackPane HBox.hgrow="ALWAYS">
                                                <children>
                                                    <PasswordField fx:id="passwordField" promptText="Enter your password" styleClass="form-field" />
                                                    <TextField fx:id="passwordVisibleField" promptText="Enter your password" styleClass="form-field" visible="false" managed="false" />
                                                </children>
                                            </StackPane>
                                            <Button fx:id="togglePasswordVisibilityButton" text="Show" onAction="#togglePasswordVisibility"
                                                    style="-fx-background-color: transparent; -fx-cursor: hand; -fx-text-fill: #475569; -fx-font-size: 12px; -fx-font-weight: bold;" />
                                        </children>
                                    </HBox>
                                </children>
                            </VBox>

                            <HBox alignment="CENTER" spacing="12.0">
                                <children>
                                    <Button fx:id="loginButton" text="Sign In" prefWidth="260.0" prefHeight="50.0"
                                            styleClass="primary-button" onAction="#handleLogin">
                                        <font>
                                            <Font name="Inter" size="16.0" />
                                        </font>
                                        <effect>
                                            <DropShadow radius="14.0" color="#2563EB55" offsetY="2.0" />
                                        </effect>
                                    </Button>
                                    <ProgressIndicator fx:id="loginProgressIndicator" prefWidth="24.0" prefHeight="24.0" visible="false" managed="false" />
                                </children>
                            </HBox>
                        </children>
                    </VBox>

                    <!-- Footer -->
                    <Label text="© 2026 Plate IQ Systems. All rights reserved." styleClass="footer-label"
                           AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="0.0"
                           AnchorPane.rightAnchor="0.0">
                        <font>
                            <Font name="Inter" size="11.0" />
                        </font>
                        <textFill>
                            <Color red="0.7" green="0.7" blue="0.7" />
                        </textFill>
                    </Label>
                </children>
            </AnchorPane>
        </StackPane>

        <!-- Welcome Animation (FadeTransition) -->
        <Label fx:id="welcomeLabel" text="Welcome back!" styleClass="welcome-label"
               AnchorPane.topAnchor="30.0" AnchorPane.rightAnchor="30.0">
            <font>
                <Font name="Inter" size="16.0" />
            </font>
            <textFill>
                <Color red="0.4" green="0.5" blue="0.6" />
            </textFill>
        </Label>
    </children>
</AnchorPane>
